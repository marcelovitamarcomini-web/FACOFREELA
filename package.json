{
  "name": "facofreela",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "npm run check && npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:hostgator": "npm run build:client && powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-hostgator-package.ps1",
    "build:server": "tsc -p tsconfig.server.json",
    "check": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@supabase/supabase-js": "^2.99.2",
    "hono": "^4.12.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
